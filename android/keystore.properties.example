# MoodWhisper Release Signing Configuration
#
# Instructions:
# 1. Copy this file to keystore.properties (remove .example extension)
# 2. Generate a keystore:
#    keytool -genkey -v -storetype JKS -keyalg RSA -keysize 2048 -validity 10000 \
#      -keystore keystore.jks -alias moodwhisper \
#      -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#      -dname "CN=MoodWhisper, OU=Development, O=MoodWhisper, L=City, ST=State, C=CN"
# 3. Or generate a PKCS12 keystore from Google Play:
#    keytool -importkeystore -srckeystore original.p12 -srcstoretype PKCS12 \
#      -destkeystore keystore.jks -deststoretype JKS
# 4. Update build.gradle to use signingConfigs.release
# 5. NEVER commit keystore.jks or keystore.properties to version control

storeFile=keystore.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=moodwhisper
keyPassword=YOUR_KEY_PASSWORD
